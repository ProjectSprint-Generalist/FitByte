# FitByte API Environment Configuration
# Copy this file to .env and update the values according to your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application environment (development, staging, production)
ENVIRONMENT=development

# Server port (default: 8080)
PORT=8080

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL database connection string
# Format: postgres://username:password@host:port/database_name?sslmode=disable
# For local development with default PostgreSQL setup:
DATABASE_URL=postgres://fitbyte_user:fitbyte_password@localhost:5432/fitbyte_db?sslmode=disable

# Alternative: If you want to use environment variables instead of connection string
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=fitbyte_user
# DB_PASSWORD=fitbyte_password
# DB_NAME=fitbyte_db
# DB_SSL_MODE=disable

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# JWT secret key for signing tokens (CHANGE THIS IN PRODUCTION!)
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=team-generalist

# =============================================================================
# EXAMPLE VALUES FOR DIFFERENT ENVIRONMENTS
# =============================================================================

# Development (local):
# ENVIRONMENT=development
# DATABASE_URL=postgres://fitbyte_user:fitbyte_password@localhost:5432/fitbyte_db?sslmode=disable
# JWT_SECRET=dev-secret-key-not-for-production

# Staging:
# ENVIRONMENT=staging
# DATABASE_URL=postgres://fitbyte_user:staging_password@staging-db:5432/fitbyte_staging?sslmode=require
# JWT_SECRET=staging-jwt-secret-key

# Production:
# ENVIRONMENT=production
# DATABASE_URL=postgres://fitbyte_user:production_password@prod-db:5432/fitbyte_prod?sslmode=require
# JWT_SECRET=super-secure-production-jwt-secret-key
